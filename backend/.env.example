# BATUHAN — Environment Variables (T4)
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------
# REQUIRED — Anthropic
# -----------------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_MAX_TOKENS=8192
CLAUDE_TEMPERATURE=0.2

# -----------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------
APP_NAME=BATUHAN
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
INTERNAL_API_KEY=change-me-in-production

# CORS — comma-separated list of allowed origins (no spaces around commas)
# For production: set to your internal dashboard URL only
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------
# File Storage (local for dev, s3 for prod)
# -----------------------------------------------------------------------
STORAGE_BACKEND=local
STORAGE_BASE_PATH=./storage

# S3 (only needed if STORAGE_BACKEND=s3)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# -----------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------
DATABASE_URL=sqlite:///./batuhan.db

# -----------------------------------------------------------------------
# Redis / Celery
# -----------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# -----------------------------------------------------------------------
# Pipeline
# -----------------------------------------------------------------------
MAX_RETRIES_PER_STEP=2
STEP_TIMEOUT_SECONDS=600
PROMPT_VERSION=1.0
PROMPTS_DIR=./prompts

